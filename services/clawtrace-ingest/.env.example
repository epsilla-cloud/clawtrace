# Server
CLAWTRACE_INGEST_HOST=0.0.0.0
CLAWTRACE_INGEST_PORT=8080
CLAWTRACE_INGEST_LOG_LEVEL=INFO

# Auth
# mock_pass       — auth always passes (dev/local only, never use in prod)
# static_keys     — validates bearer tokens against CLAWTRACE_INGEST_STATIC_KEYS_JSON
# remote_api      — validates against api.clawtrace.ai (PRODUCTION mode)
CLAWTRACE_INGEST_AUTH_MODE=remote_api
CLAWTRACE_INGEST_STATIC_KEYS_JSON={"REDACTED_KEY":"REDACTED_ACCOUNT"}
# remote_api mode: backend URL and shared internal secret
CLAWTRACE_INGEST_BACKEND_URL=https://api.clawtrace.ai
CLAWTRACE_INGEST_INTERNAL_SECRET=change-me-must-match-backend

# Raw storage sink (data lake only)
# Supported providers: gcs, azure_blob, aws_s3
CLAWTRACE_INGEST_STORAGE_PROVIDER=gcs
CLAWTRACE_INGEST_RAW_BUCKET=clawtrace-raw
CLAWTRACE_INGEST_RAW_PREFIX=raw/v1

# GCS profile (used when STORAGE_PROVIDER=gcs)
# ADC/service account auth is expected.

# Azure Blob / ADLS Gen2 profile (used when STORAGE_PROVIDER=azure_blob)
# Set container here (or reuse RAW_BUCKET).
CLAWTRACE_INGEST_AZURE_CONTAINER=
# If using managed identity: set account URL like https://<account>.blob.core.windows.net
CLAWTRACE_INGEST_AZURE_ACCOUNT_URL=
# Optional alternative to account URL + managed identity:
CLAWTRACE_INGEST_AZURE_CONNECTION_STRING=

# AWS S3 profile (used when STORAGE_PROVIDER=aws_s3)
# Credentials use default AWS SDK chain (role/instance profile/env vars).
CLAWTRACE_INGEST_AWS_REGION=
# Optional for S3-compatible endpoints (R2/MinIO/etc):
CLAWTRACE_INGEST_AWS_ENDPOINT_URL=

# Optional downstream trigger
# Example: projects/your-project/topics/clawtrace-ingest
CLAWTRACE_INGEST_PUBSUB_TOPIC=

# Payment service — deficit guard (leave empty to disable / allow all)
CLAWTRACE_INGEST_PAYMENT_URL=http://localhost:8083
CLAWTRACE_INGEST_DEFICIT_CHECK_INTERVAL_SECONDS=900
