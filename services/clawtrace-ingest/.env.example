# Server
CLAWTRACE_INGEST_HOST=0.0.0.0
CLAWTRACE_INGEST_PORT=8080
CLAWTRACE_INGEST_LOG_LEVEL=INFO

# Auth
# mock_pass (default) means auth check always passes for development.
# static_keys validates bearer tokens from CLAWTRACE_INGEST_STATIC_KEYS_JSON.
CLAWTRACE_INGEST_AUTH_MODE=mock_pass
CLAWTRACE_INGEST_STATIC_KEYS_JSON={"REDACTED_KEY":"REDACTED_ACCOUNT"}

# Raw storage sink
# local writes JSONL event files under CLAWTRACE_INGEST_LOCAL_DATA_ROOT
# gcs writes JSONL event files to CLAWTRACE_INGEST_GCS_BUCKET/CLAWTRACE_INGEST_GCS_PREFIX
CLAWTRACE_INGEST_RAW_SINK=local
CLAWTRACE_INGEST_LOCAL_DATA_ROOT=./data/raw
CLAWTRACE_INGEST_GCS_BUCKET=
CLAWTRACE_INGEST_GCS_PREFIX=raw-events

# Idempotency store
CLAWTRACE_INGEST_ENABLE_IDEMPOTENCY=true
CLAWTRACE_INGEST_IDEMPOTENCY_DB_PATH=./data/idempotency.sqlite3

# Optional downstream trigger
# Example: projects/your-project/topics/clawtrace-ingest
CLAWTRACE_INGEST_PUBSUB_TOPIC=
