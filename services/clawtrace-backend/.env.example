# ── Auth (must match UI JWT secret) ────────────────────────────────────
CLAWTRACE_BACKEND_JWT_SECRET=change-me-must-match-ui
CLAWTRACE_BACKEND_JWT_ALGORITHM=HS256
CLAWTRACE_BACKEND_JWT_COOKIE_NAME=auth_token

# ── Database (Neon PostgreSQL, same as UI) ─────────────────────────────
CLAWTRACE_BACKEND_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/clawtrace?sslmode=require

# ── Server ─────────────────────────────────────────────────────────────
CLAWTRACE_BACKEND_HOST=0.0.0.0
CLAWTRACE_BACKEND_PORT=8082

# ── API keys ───────────────────────────────────────────────────────────
CLAWTRACE_BACKEND_API_KEY_PREFIX=ct_live

# ── Internal shared secret (must match ingest + payment services) ──────
CLAWTRACE_BACKEND_INTERNAL_SECRET=change-me-shared-secret

# ── PuppyGraph ─────────────────────────────────────────────────────────
CLAWTRACE_BACKEND_PUPPYGRAPH_URL=https://puppy.clawtrace.ai
CLAWTRACE_BACKEND_PUPPYGRAPH_USER=puppygraph
CLAWTRACE_BACKEND_PUPPYGRAPH_PASSWORD=REDACTED

# ── Payment service — deficit guard (leave empty to disable) ───────────
CLAWTRACE_BACKEND_PAYMENT_URL=https://pay.clawtrace.ai
CLAWTRACE_BACKEND_DEFICIT_CHECK_INTERVAL_SECONDS=900
