# ── Server ──────────────────────────────────────────────────────────────
CLAWTRACE_PAYMENT_HOST=0.0.0.0
CLAWTRACE_PAYMENT_PORT=8083
CLAWTRACE_PAYMENT_LOG_LEVEL=INFO

# ── Auth (must match backend + UI) ─────────────────────────────────────
CLAWTRACE_PAYMENT_JWT_SECRET=change-me-must-match-backend-and-ui
CLAWTRACE_PAYMENT_JWT_ALGORITHM=HS256
CLAWTRACE_PAYMENT_JWT_COOKIE_NAME=auth_token
CLAWTRACE_PAYMENT_INTERNAL_SECRET=change-me-must-match-backend

# ── Database (same Neon PostgreSQL as backend/UI) ──────────────────────
CLAWTRACE_PAYMENT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/clawtrace?sslmode=require

# ── Stripe ─────────────────────────────────────────────────────────────
CLAWTRACE_PAYMENT_STRIPE_SECRET_KEY=sk_live_...
CLAWTRACE_PAYMENT_STRIPE_WEBHOOK_SECRET=whsec_...

# ── Credits ────────────────────────────────────────────────────────────
CLAWTRACE_PAYMENT_DEFAULT_SIGNUP_CREDITS=200
CLAWTRACE_PAYMENT_REFERRAL_NEW_USER_CREDITS=200
CLAWTRACE_PAYMENT_REFERRAL_REFERRER_CREDITS=200
CLAWTRACE_PAYMENT_CREDIT_EXPIRATION_DAYS=730
CLAWTRACE_PAYMENT_CREDITS_PER_DOLLAR=100
CLAWTRACE_PAYMENT_LOW_CREDIT_THRESHOLD=50

# ── Pricing table (JSON — credits per unit) ────────────────────────────
# Note: LLM tokens from user traces are NOT billed here (users run their
# own OpenClaw). Only Tracy agent chat tokens from the API backend are billed.
CLAWTRACE_PAYMENT_PRICING_TABLE_JSON={"tracy_input_token_1k": 0.5, "tracy_output_token_1k": 1.5, "tool_call": 0.1, "storage_gb_hour": 2.0}

# ── Scheduler intervals (seconds) ─────────────────────────────────────
CLAWTRACE_PAYMENT_HARVEST_INTERVAL_SECONDS=1800
CLAWTRACE_PAYMENT_NOTIFICATION_INTERVAL_SECONDS=3600
CLAWTRACE_PAYMENT_USAGE_POLL_INTERVAL_SECONDS=900

# ── Audit log — blob storage ──────────────────────────────────────────
CLAWTRACE_PAYMENT_STORAGE_PROVIDER=azure_blob
CLAWTRACE_PAYMENT_AUDIT_BUCKET=clawtrace-billing
CLAWTRACE_PAYMENT_AUDIT_PREFIX=billing/v1
CLAWTRACE_PAYMENT_AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...

# ── Notifications — Azure Email Communication Service ─────────────────
CLAWTRACE_PAYMENT_AZURE_ECS_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=...
CLAWTRACE_PAYMENT_AZURE_ECS_SENDER=billing@clawtrace.ai
CLAWTRACE_PAYMENT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
CLAWTRACE_PAYMENT_NOTIFICATION_ENABLED=true
