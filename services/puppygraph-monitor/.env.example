# PuppyGraph connection
PUPPYGRAPH_URL=https://puppy.clawtrace.ai
PUPPYGRAPH_USER=puppygraph
PUPPYGRAPH_PASSWORD=

# PuppyGraph VM SSH access (for container restart)
PUPPYGRAPH_VM_IP=172.176.185.172
PUPPYGRAPH_VM_USER=azureuser
PUPPYGRAPH_SSH_KEY=/opt/clawtrace/puppygraph-monitor/clawtrace-ingest-vm_key.pem
PUPPYGRAPH_CONTAINER=puppy

# Slack alerts
SLACK_WEBHOOK_URL=

# Probe config
PROBE_TRACE_ID=3ec65672-9845-4341-adc8-1a6b7fabfc71
MONITOR_INTERVAL_SECONDS=1800
RETRY_COUNT=3
RETRY_DELAY_SECONDS=30
QUERY_TIMEOUT_SECONDS=30
